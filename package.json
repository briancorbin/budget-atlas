{
  "name": "budget-atlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An interactive examination of how Americans live on what they earn — across cities, tax regimes, and household configurations.",
  "packageManager": "yarn@4.9.1",
  "scripts": {
    "start": "vite",
    "tunnel": "./scripts/tunnel.sh",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "yarn typecheck && yarn lint && yarn format:check && yarn test",
    "render-branding": "./scripts/render-branding.sh",
    "check-links": "./audit/links/check.sh",
    "audit:seed-issues": "node audit/links/seed-issues.mjs",
    "audit:staleness": "node audit/staleness/seed-issue.mjs",
    "audit:inventory": "node --experimental-strip-types scripts/source-inventory.mjs",
    "dev:worker": "wrangler dev --local --persist-to=.wrangler/state",
    "dev:worker:seed": "wrangler d1 execute budget-atlas-audit --local --file=worker/schema.sql --persist-to=.wrangler/state",
    "db:sync": "./audit/links/sync-d1-from-prod.sh"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260506.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  }
}
