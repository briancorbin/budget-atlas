# Dependencies
node_modules/

# This project uses Yarn — yarn.lock is the source of truth.
# Keep npm's lockfile out so CF Pages (and anyone running `npm install`)
# doesn't generate a parallel, drifting lockfile.
package-lock.json

# Yarn 4 internals (per https://yarnpkg.com/getting-started/qa#which-files-should-be-gitignored):
# install-state, cache, and unplugged are local-only. We use Corepack
# (packageManager field in package.json) rather than vendoring Yarn into
# .yarn/releases, so the entire .yarn/ tree is local-only here.
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Build output
dist/
dist-ssr/
dist-tsbuildinfo/
*.tsbuildinfo

# Editors
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env
.env
.env.*

# OS
Thumbs.db

# Wrangler local state
.wrangler/

# Claude Code local settings & scratch
.claude/settings.local.json
.claude/scheduled_tasks.lock
# Parallel-session worktrees that Claude Code creates ad hoc — not part
# of the main repo and shouldn't be committed (git treats nested clones
# as submodules by default).
.claude/worktrees/
